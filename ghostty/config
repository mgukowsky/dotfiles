# Fonts
font-family = FiraCode Nerd Font
font-family-bold = FiraCode Nerd Font
font-family-italic = VictorMono Nerd Font
font-family-bold-italic = VictorMono Nerd Font
font-size = 13.5
font-feature = -liga
font-feature = -calt

# Keymaps
keybind = page_up=scroll_page_up
keybind = page_down=scroll_page_down
keybind = home=scroll_to_top
keybind = end=scroll_to_bottom

# Colors
background-opacity = 0.8
background-opacity-cells = true

background = 2d2d2d
foreground = d3d0c8

